# ============================================
# Supabase (relatorio_bias)
# ============================================
VITE_SUPABASE_URL=
VITE_SUPABASE_SERVICE_ROLE_SECRET=

# ============================================
# uazapi (lookup nome da instância por token)
# ============================================
VITE_UAZAPI_URL=
VITE_UAZAPI_TOKEN=

# ============================================
# Meta Ads — gestores ativos (Renan, Weslei)
#
# - VITE_META_TOKEN_*  : access token (obrigatório, é a "apiKey" do Meta)
# - VITE_META_ACCOUNT_*: OPCIONAL — Ad Account ID (act_XXXXXXXXX). Se vazio,
#   o sistema descobre todas as contas de anúncios disponíveis no token.
# ============================================
VITE_META_TOKEN_RENAN=
VITE_META_ACCOUNT_RENAN=
VITE_META_TOKEN_WESLEI=
VITE_META_ACCOUNT_WESLEI=
VITE_META_TOKEN_ANDRE=
VITE_META_ACCOUNT_ANDRE=

# ============================================
# Monday (board de clientes)
# Token: developer token de https://burstmidia.monday.com/admin/integrations/api
# ============================================
VITE_MONDAY_TOKEN=
VITE_MONDAY_BOARD_ID=3710852837
